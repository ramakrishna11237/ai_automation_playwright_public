{
  "name": "ai-automation-framework",
  "version": "2.0.0",
  "scripts": {
    "help": "ts-node src/help.ts",
    "label:suggest": "ts-node src/utils/LabelSuggestCLI.ts",
    "label:suggest:smoke": "ts-node src/utils/LabelSuggestCLI.ts src/tests/smoke",
    "test:demo": "playwright test --config=playwright.config.ts --project=smoke smoke/framework-demo.spec.ts",
    "test:demo:headed": "cross-env HEADLESS=false playwright test --config=playwright.config.ts --project=smoke smoke/framework-demo.spec.ts",
    "test:demo:all": "playwright test --config=playwright.config.ts --project=demo",
    "test:demo:ecommerce": "playwright test --config=playwright.config.ts --project=demo:ecommerce",
    "test:demo:banking": "playwright test --config=playwright.config.ts --project=demo:banking",
    "test:demo:healthcare": "playwright test --config=playwright.config.ts --project=demo:healthcare",
    "test:demo:all-layers": "playwright test --config=playwright.config.ts --project=demo:all-layers",
    "test:demo:internet": "playwright test --config=playwright.config.ts --project=demo:internet",
    "test:orangehrm:leave": "playwright test --config=playwright.config.ts --project=orangeHRM:leave",
    "test:demo:headed:all": "cross-env HEADLESS=false playwright test --config=playwright.config.ts --project=demo",
    "setup": "ts-node src/setup.ts",
    "test": "playwright test --config=playwright.config.ts",
    "test:smoke": "playwright test --config=playwright.config.ts --project=smoke",
    "test:sanity": "playwright test --config=playwright.config.ts --project=sanity",
    "test:regression": "playwright test --config=playwright.config.ts --project=regression",
    "test:chromium": "playwright test --config=playwright.config.ts --project=chromium",
    "test:firefox": "playwright test --config=playwright.config.ts --project=firefox",
    "test:webkit": "playwright test --config=playwright.config.ts --project=webkit",
    "test:mobile": "playwright test --config=playwright.config.ts --project=mobile-chrome",
    "test:ci": "cross-env CI=true playwright test --config=playwright.config.ts",
    "test:failed": "playwright test --config=playwright.config.ts --last-failed",
    "test:failed:headed": "cross-env HEADLESS=false playwright test --config=playwright.config.ts --last-failed",
    "agent": "ts-node src/agent/index.ts",
    "agent:dry": "cross-env AGENT_DRY_RUN=true ts-node src/agent/index.ts",
    "agent:ai": "cross-env FW_LLM=true ts-node src/agent/index.ts",
    "agent:validate": "ts-node src/agent/validate.ts",
    "agent:precise": "ts-node src/agent/precise.ts",
    "test:headed": "cross-env HEADLESS=false playwright test --config=playwright.config.ts",
    "test:debug": "cross-env PWDEBUG=1 playwright test --config=playwright.config.ts",
    "test:debug:spec": "cross-env PWDEBUG=1 HEADLESS=false playwright test --config=playwright.config.ts",
    "test:debug:visual": "cross-env HEADLESS=false FW_DEBUG=true FW_LOG_LEVEL=debug playwright test --config=playwright.config.ts",
    "test:debug:log": "cross-env FW_LOG_LEVEL=debug playwright test --config=playwright.config.ts",
    "report": "playwright show-report test-results/html-report",
    "visual:approve": "ts-node src/utils/VisualApprove.ts",
    "visual:approve:dry": "ts-node src/utils/VisualApprove.ts --dry",
    "clean": "rimraf test-results learning-db.json"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "@types/pdf-parse": "^1.1.5",
    "diff": "^5.1.0",
    "dotenv": "^16.4.5",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2"
  }
}
