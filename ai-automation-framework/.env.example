# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://records-perf2509.hxgn-oncall.org/webrms/login/login.jsp
APP_USERNAME=""
APP_PASSWORD=""

# ── Browser ────────────────────────────────────────────────────────────────────
BASE_URL=https://records-perf2509.hxgn-oncall.org
HEADLESS=true

# ── CI ─────────────────────────────────────────────────────────────────────────
CI=false

# ── Framework timeouts (milliseconds) ─────────────────────────────────────────
FW_TIMEOUT=5000
FW_WAIT_TIMEOUT=5000
FW_MAX_BACKOFF_MS=2000
FW_IFRAME_TIMEOUT=10000
FW_SLOW_TYPE_MS=80

# ── Framework retries ──────────────────────────────────────────────────────────
FW_MAX_RETRIES=3
FW_STEP_RETRIES=2
FW_BACKOFF=true

# ── Framework learning ─────────────────────────────────────────────────────────
FW_LEARNING=true
FW_DB_PATH=learning-db.json

# ── Framework logging ──────────────────────────────────────────────────────────
# Options: debug | info | warn | error
FW_LOG_LEVEL=info

# ── Output directories ─────────────────────────────────────────────────────────
FW_SCREENSHOT_DIR=test-results/screenshots
FW_DOWNLOAD_DIR=test-results/downloads
FW_DIFF_DIR=test-results/diffs
FW_LOG_DIR=test-results/logs

# ── LLM Layer 5 (local Ollama — free, no data leaves machine) ──────────────────
# Setup: 1) Install Ollama: https://ollama.com
#        2) Run: ollama pull llama3 && ollama pull codellama
#        3) Set FW_LLM=true below
FW_LLM=true
FW_LLM_MODEL=llama3
FW_LLM_FALLBACK_MODEL=codellama
FW_LLM_MIN_CONFIDENCE=70
FW_LLM_TIMEOUT_MS=8000
